# Supabase (production)
SUPABASE_URL=https://<PROJE_REF>.supabase.co
SUPABASE_ANON_KEY=<supabase-dashboard-settings-api-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-dashboard-settings-api-service-role-key>

# Frontend (Vite) — build-time env vars for Netlify
VITE_SUPABASE_URL=https://<PROJE_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-ile-aynı>

# API URL — frontend'in API'ye ulaşacağı adres
# Netlify'da aynı domain olduğu için boş bırakın (otomatik /api)
VITE_API_URL=

# API server port (sadece local dev için)
PORT=3000

# CORS: hangi origin'lere izin verilecek (virgülle ayırın)
# Netlify'da sitenizin URL'si + localhost
ALLOWED_ORIGINS=https://<site-adi>.netlify.app,http://localhost:5173
