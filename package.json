{
  "name": "vig-fifa-tournament",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:api": "bun --filter @vig/api dev",
    "dev:web": "bun --filter @vig/web dev",
    "build:web": "bun --filter @vig/web build",
    "test": "bun --filter '*' test",
    "lint": "bun biome check .",
    "lint:fix": "bun biome check --write .",
    "format": "bun biome format --write .",
    "seed": "bun run scripts/seed.ts",
    "seed:reset": "bun run scripts/seed.ts --reset",
    "create-players": "bun run scripts/create-players.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0"
  }
}
